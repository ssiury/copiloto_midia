# Variáveis lidas pelo docker-compose.yml na raiz do projeto.
# Copie este arquivo para ".env" e ajuste os valores conforme necessário.

# Postgres
DB_DATABASE=copiloto_midia
DB_USERNAME=copiloto_midia
DB_PASSWORD=change-me

# Portas expostas no host
NGINX_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
VITE_PORT=5173

# Frontend
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000/api
